# ==========================================================
# EMADS .gitignore
# ==========================================================

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Virtual environment ---
venv/
.venv/
env/

# --- Environment variables (contains API keys!) ---
.env

# --- IDE / Editor settings ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- pytest ---
.pytest_cache/
htmlcov/
.coverage

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Distribution / packaging ---
dist/
build/
*.egg-info/

# --- Jupyter Notebook checkpoints ---
.ipynb_checkpoints/

# --- Runtime outputs (regenerated by the pipeline) ---
data/models/*.pkl
data/plots/*.png
data/processed/*.csv
reports/*.pdf
reports/*.txt
